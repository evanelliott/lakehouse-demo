{
  "name": "Lakehouse Demo - Sandboxed Dev",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "/app",
  "initializeCommand": "bash .devcontainer/fetch_jars.sh",
  "postCreateCommand": "bash .devcontainer/dev_setup.sh",
  // FIX: Run your git registration and your new background daemon cleanly in sequence
  "postStartCommand": "bash -i -l -c 'bash .devcontainer/start_spark_connect.sh'",
  "userEnvProbe": "loginShell",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "charliermarsh.ruff",
        "ms-python.python",
        "ms-python.mypy-vscode",
        "tamasfe.even-better-toml",
        "mtakhtarov.duckdb-sql",
        "apache.pyspark-explorer"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/venv/bin/python3",
        "python.analysis.extraPaths": [
          "/app"
        ],
        "python.testing.pytestEnabled": true,
        "telemetry.telemetryLevel": "off",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.ruff": "explicit",
          "source.organizeImports.ruff": "explicit"
        }
      }
    }
  },
  "containerEnv": {
    "PYTHONPATH": "/app",
    "PYARROW_IGNORE_TIMEZONE": "1",
    "SPARK_REMOTE": "sc://localhost:15002"
  },
  "remoteUser": "vscode"
}