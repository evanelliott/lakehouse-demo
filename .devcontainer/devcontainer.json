{
  "name": "Lakehouse Demo - Sandboxed Dev",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "/app",
  
  "postCreateCommand": "bash scripts/dev_setup.sh",
  "postStartCommand": "git config --global --add safe.directory /app",
  
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "charliermarsh.ruff",
        "ms-python.python",
        "ms-python.mypy-vscode",
        "tamasfe.even-better-toml",
        "mtakhtarov.duckdb-sql",
        "apache.pyspark-explorer"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/venv/bin/python3",
        "python.analysis.extraPaths": ["/app"],
        "python.testing.pytestEnabled": true,
        "telemetry.telemetryLevel": "off",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.ruff": "explicit",
          "source.organizeImports.ruff": "explicit"
        }
      }
    }
  },
  "containerEnv": {
    "PYTHONPATH": "/app",
    "PYARROW_IGNORE_TIMEZONE": "1",
    "SPARK_LOCAL_IP": "127.0.0.1"
  },
  "remoteUser": "vscode"
}
