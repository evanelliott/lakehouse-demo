# =========================================================================
# SYSTEM & TOOLING GATES
# =========================================================================
# --- Python / uv / Tooling ---
.venv/
__pycache__/
*.py[cod]
.ipynb_checkpoints/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# --- OS Specific ---
.DS_Store
Thumbs.db


# =========================================================================
# SECURITY & PLATFORM BOUNDARIES
# =========================================================================
# --- Environment & Secrets ---
.env
.env.*
*.env


# =========================================================================
# TESTING & DATA LAKE DEFENSTIVE ASSETS
# =========================================================================
# --- Testing Assets & Cassettes ---
# DO NOT ignore your text-based VCR cassettes or static extraction fixtures.
# They act as your immutable offline logic validator contracts.
!tests/unit/scraper/fixtures/*
!tests/unit/scraper/cassettes/**/*.yaml

# --- Data & Lakehouse ---
# Ignore all raw/local data except for our verified governance layer
*.parquet
!src/governance/*.parquet
!src/governance/*.csv
data/
logs/
*.db
*.db.wal


# =========================================================================
# INFRASTRUCTURE SIMULATION PROFILES
# =========================================================================
# --- Spark / Java ---
metastore_db/
spark-warehouse/
derby.log
*.jar
*.log

# --- Docker & DevContainer ---
.devcontainer/*.local.json
minio_data/
.minio.sys/

# --- Other ---
/_legacy
