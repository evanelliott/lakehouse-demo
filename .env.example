# =================================================================
# PROJECT SETTINGS
# =================================================================
PROJECT_NAME=lakehouse-demo
COMPOSE_PROJECT_NAME=lakehouse_demo

# =================================================================
# RESOURCE LIMITS (Optimized for 16GB RAM / M4)
# =================================================================
TRINO_MEM_LIMIT=4G
TRINO_HEAP_MAX=3G

# NEW: Query-level safety caps for Trino 400+
# These prevent a single query from hogging the entire 4GB container
TRINO_QUERY_MAX_MEM=2G
TRINO_QUERY_MAX_TOTAL_MEM=3G

AIRFLOW_MEM_LIMIT=2G
POSTGRES_MEM_LIMIT=512M
MINIO_MEM_LIMIT=512M
JUPYTER_MEM_LIMIT=1G

# =================================================================
# SERVICE NAMES (Internal Network Aliases)
# =================================================================
MINIO_HOST=minio
CATALOG_HOST=iceberg-rest
TRINO_HOST=trino
AIRFLOW_HOST=airflow
AIRFLOW_DB_HOST=airflow-db
JUPYTER_HOST=jupyter

# =================================================================
# INTERNAL PORTS (Container-to-Container)
# =================================================================
MINIO_INTERNAL_PORT=9000
MINIO_CONSOLE_INTERNAL_PORT=9001
CATALOG_INTERNAL_PORT=8181
TRINO_INTERNAL_PORT=8080
AIRFLOW_INTERNAL_PORT=8080
POSTGRES_INTERNAL_PORT=5432
JUPYTER_INTERNAL_PORT=8888

# =================================================================
# EXTERNAL PORTS (Your Mac Mini M4)
# =================================================================
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
CATALOG_PORT=8181
TRINO_PORT=8080
AIRFLOW_PORT=8085
JUPYTER_PORT=8888

# =================================================================
# CREDENTIALS & IMAGES
# =================================================================
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=your_secure_password
AWS_REGION=us-east-1

AIRFLOW_IMAGE=apache/airflow:2.7.2-python3.10
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASS=your_secure_password
AIRFLOW_DB_NAME=airflow
AIRFLOW_FERNET_KEY=your_fernet_key_here  # Generate with: python3 -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"

JUPYTER_TOKEN=lakehouse
